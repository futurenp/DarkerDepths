{
  "multipart": [
    {
      "apply": {
        "model": "darkerdepths:block/stripped_glowshroom_post"
      },
      "when": {
        "axis": "y"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/stripped_glowshroom_post",
        "x": 90,
        "y": 90
      },
      "when": {
        "axis": "x"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/stripped_glowshroom_post",
        "x": 90
      },
      "when": {
        "axis": "z"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/chain_small"
      },
      "when": {
        "connect_down": "chain"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/chain_small_top"
      },
      "when": {
        "connect_up": "chain"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/chain_small_top",
        "x": 90
      },
      "when": {
        "connect_north": "chain"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/chain_small",
        "x": 90
      },
      "when": {
        "connect_south": "chain"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/chain_small_top",
        "x": 90,
        "y": 90
      },
      "when": {
        "connect_west": "chain"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/chain_small",
        "x": 90,
        "y": 90
      },
      "when": {
        "connect_east": "chain"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/stripped_glowshroom_post_connect"
      },
      "when": {
        "connect_down": "other_post"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/stripped_glowshroom_post_connect_top"
      },
      "when": {
        "connect_up": "other_post"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/stripped_glowshroom_post_connect_top",
        "x": 90
      },
      "when": {
        "connect_north": "other_post"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/stripped_glowshroom_post_connect",
        "x": 90
      },
      "when": {
        "connect_south": "other_post"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/stripped_glowshroom_post_connect_top",
        "x": 90,
        "y": 90
      },
      "when": {
        "connect_west": "other_post"
      }
    },
    {
      "apply": {
        "model": "darkerdepths:block/stripped_glowshroom_post_connect",
        "x": 90,
        "y": 90
      },
      "when": {
        "connect_east": "other_post"
      }
    }
  ]
}